# Figma Personal Access Token
# Create at: https://www.figma.com/settings -> Security -> Personal access tokens
# Required scopes for phase 1:
#   file_content:read, file_comments:write, library_assets:read,
#   library_content:read, current_user:read
FIGMA_TOKEN=

# Optional: default file key used when a tool call omits it
FIGMA_DEFAULT_FILE_KEY=
